{
    "name": "woocommerce-delivery-notes",
    "version": "7.1.2",
    "private": true,
    "description": "Print Invoice & Delivery Notes for WooCommerce",
    "author": "Tyche Softwares",
    "license": "Tyche Softwares",
    "main": "build/index.js",
    "scripts": {
        "build": "wp-scripts build",
        "start": "wp-scripts start",
        "format": "prettier --write \"src/**/*.{js,jsx}\"",
        "lint:css": "wp-scripts lint-style",
        "lint:js": "wp-scripts lint-js",
        "packages-update": "wp-scripts packages-update",
        "makejsstring": "node .bin/make-string.js",
        "makepot": "wp i18n make-pot . languages/woocommerce-delivery-notes.pot --skip-js --exclude=src,vendor,node_modules --merge=languages/js.pot",
        "deploy": "npm-run-all build makepot copy",
        "composer": "composer install --no-dev --optimize-autoloader",
        "clean": "rm -rf dist",
        "translate": "wp i18n make-pot . languages/woocommerce-delivery-notes.pot && node generate-po.js && node compile-mo.js",
        "translate:deepl": "node --env-file=.env translate-po.mjs && node compile-mo.js",
        "package": "node build-plugin.js",
        "package:wc": "node build-plugin.js --variant=wc",
        "release:non-wc": "npm run build && node build-plugin.js",
        "release:wc": "WCDN_WC_BUILD=true npm run build && node build-plugin.js --variant=wc",
        "release": "npm run clean && npm run composer && npm run release:non-wc && npm run release:wc",
        "release:svn": "npm run clean && npm run build && npm run i18n && node build-plugin.js --variant=svn"
    },
    "devDependencies": {
        "@wordpress/eslint-plugin": "^22.22.0",
        "@wordpress/scripts": "^30.12.0",
        "archiver": "^7.0.1",
        "browser-sync": "^3.0.4",
        "browser-sync-webpack-plugin": "^2.4.0",
        "eslint": "^8.57.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "gettext-parser": "^9.0.2"
    },
    "dependencies": {
        "@fontsource/inter": "^5.2.8",
        "@wordpress/icons": "^11.7.0",
        "react-router-dom": "^6.23.1",
        "react-select": "^5.8.0"
    }
}
